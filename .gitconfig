[user]
	name = Ben Dixon
	email = bdixon@cloudflare.com
	signingkey = ~/.ssh/id_ed25519.pub
[github]
	user = nurodev
[color]
	branch = auto
	diff = auto
	interactive = auto
	status = auto
[core]
	autocrlf = input
	editor = nano
	excludesfile = ~/.gitignore
[init]
	defaultBranch = main
[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
[url "ssh://git@github.com/"]
	insteadOf = github:
[url "ssh://git@github.com/"]
	insteadOf = gh:
[diff "lockb"]
	textconv = bun
	binary = true
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
